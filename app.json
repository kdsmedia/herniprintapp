{
  "expo": {
    "name": "HERNIPRINT",
    "slug": "herni-print",
    "owner": "sidhanie06",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.altomedia.herniprint",
      "googleServicesFile": "./google-services.json",
      "versionCode": 3,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.SEND_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.CALL_PHONE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.USB_PERMISSION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.NFC",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ],
      "blockedPermissions": []
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "HERNIPRINT memerlukan akses kamera untuk memindai dokumen dan mengambil foto untuk dicetak.",
          "microphonePermission": "HERNIPRINT memerlukan akses mikrofon untuk fitur perekaman."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HERNIPRINT memerlukan lokasi untuk mencari printer Bluetooth terdekat.",
          "locationAlwaysPermission": "HERNIPRINT memerlukan lokasi untuk mendeteksi perangkat printer.",
          "locationWhenInUsePermission": "HERNIPRINT memerlukan lokasi untuk pencarian printer Bluetooth."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "HERNIPRINT memerlukan akses kontak untuk mengisi data penerima pada resi dan label."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "HERNIPRINT memerlukan akses galeri untuk memilih gambar yang akan dicetak.",
          "cameraPermission": "HERNIPRINT memerlukan kamera untuk mengambil foto langsung untuk dicetak."
        }
      ],
      [
        "expo-document-picker",
        {}
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "HERNIPRINT memerlukan Bluetooth untuk menghubungkan dan berkomunikasi dengan printer thermal."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "1.9.25",
            "usesCleartextTraffic": true,
            "enableProguardInReleaseBuilds": true
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6881903056221433~9544311237"
        }
      ],
      "./plugins/withUSBHost.js",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "15e1de73-fe52-4916-915a-849dff2f800b"
      }
    }
  }
}
